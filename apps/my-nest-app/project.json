{
  "name": "my-nest-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/my-nest-app/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --project tsconfig.app.json",
        "cwd": "apps/my-nest-app"
      },
      "configurations": {
        "development": {
          "command": "tsc --project tsconfig.app.json",
          "cwd": "apps/my-nest-app"
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/my-nest-app/package.json",
        "{workspaceRoot}/dist/apps/my-nest-app/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/apps/my-nest-app/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/apps/my-nest-app/main.js",
        "cwd": ".",
        "readyWhen": "🚀 Application is running on:"
      },
      "dependsOn": ["build"]
    }
  }
}
